{
  "expo": {
    "name": "LocalShop",
    "slug": "localshop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "localshop",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.localshop.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LocalShop uses your location to show shops near you on the map.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.localshop.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LocalShop to use your location to show shops near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LocalShop accesses your photos so you can add product images.",
          "cameraPermission": "LocalShop uses your camera to photograph products."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.localshop.app",
          "enableGooglePay": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f7f130c5-9754-4c04-80c1-a080fb50a4fe"
      }
    },
    "owner": "aidannuge"
  }
}
