# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/local-shop

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS (comma-separated origins in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:19006
ADMIN_WEB_URL=http://localhost:3002
MERCHANT_WEB_URL=http://localhost:3000

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_NOTIFICATION_URL=

# Google Maps API (for address geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_COUNTRY=CA
STRIPE_CONNECT_REFRESH_URL=http://localhost:3002/connect/refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:3002/connect/return
STRIPE_PLATFORM_FEE_PERCENT=2.9
STRIPE_PLATFORM_FEE_FIXED_CENTS=30

# Local dev only: auto-mark orders paid without Stripe
STRIPE_SKIP_PAYMENTS=true
